{
    "version": 2,
    "builds": [
        {
            "src": "api/config.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/index.html",
            "use": "@vercel/static"
        },
        {
            "src": "frontend/styles.css",
            "use": "@vercel/static"
        },
        {
            "src": "frontend/app.js",
            "use": "@vercel/static"
        },
        {
            "src": "frontend/i18n.js",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/config",
            "dest": "/api/config.py"
        },
        {
            "src": "/api/(.*)",
            "dest": "https://aivoice.up.railway.app/api/$1"
        },
        {
            "src": "/vapi-webhook",
            "dest": "https://aivoice.up.railway.app/vapi-webhook"
        },
        {
            "src": "/health",
            "dest": "https://aivoice.up.railway.app/health"
        },
        {
            "src": "/styles.css",
            "dest": "/frontend/styles.css"
        },
        {
            "src": "/app.js",
            "dest": "/frontend/app.js"
        },
        {
            "src": "/i18n.js",
            "dest": "/frontend/i18n.js"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/index.html"
        }
    ]
}