{
    "version": 2,
    "builds": [
        {
            "src": "api/config.py",
            "use": "@vercel/python"
        },
        {
            "src": "api/query.py",
            "use": "@vercel/python"
        },
        {
            "src": "api/generate-document.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/index.html",
            "use": "@vercel/static"
        },
        {
            "src": "frontend/styles.css",
            "use": "@vercel/static"
        },
        {
            "src": "frontend/app.js",
            "use": "@vercel/static"
        },
        {
            "src": "frontend/i18n.js",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/config",
            "dest": "/api/config.py"
        },
        {
            "src": "/api/query",
            "dest": "/api/query.py"
        },
        {
            "src": "/api/generate-document",
            "dest": "/api/generate-document.py"
        },
        {
            "src": "/styles.css",
            "dest": "/frontend/styles.css"
        },
        {
            "src": "/app.js",
            "dest": "/frontend/app.js"
        },
        {
            "src": "/i18n.js",
            "dest": "/frontend/i18n.js"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/index.html"
        }
    ],
    "env": {
        "RAILWAY_BACKEND_URL": "https://aivoice.up.railway.app"
    }
}