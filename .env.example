# ── NyayaVoice Environment Variables ──────────────────────
# Copy this file to .env and fill in your keys:
#   copy .env.example .env

# Vapi keys — REQUIRED for voice calls and emergency message generation
# VAPI_API_KEY = from Dashboard > API Keys
# VAPI_PUBLIC_KEY = from Dashboard > Public Key (needed for browser voice calls)
# VAPI_PHONE_NUMBER_ID = from Dashboard > Phone Numbers (needed for outbound emergency voice calls)
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
VAPI_PHONE_NUMBER_ID=

# Qdrant — leave as :memory: for in-memory (no Docker needed)
# Or sign up free at https://cloud.qdrant.io and paste your cluster URL
QDRANT_URL=:memory:
QDRANT_API_KEY=

# Backend URL (used for document download links)
BACKEND_URL=http://localhost:8000
GOOGLE_GENAI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
PRIMARY_LLM_MODEL=gemini-2.5-flash
PRIMARY_LLM_TEMPERATURE=0.4
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
